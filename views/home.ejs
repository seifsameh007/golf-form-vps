<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="Golf House Development - اكتشف مشاريعنا العقارية المميزة">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { tajawal: ['Tajawal', 'sans-serif'] },
          colors: {
            gold: { 50: '#fdf9e7', 100: '#fbf0b5', 200: '#f5e06b', 300: '#e8c820', 400: '#d4af37', 500: '#b8960c', 600: '#957a0a', 700: '#715c08', 800: '#4d3f06', 900: '#2a2103' },
            dark: { 50: '#f5f5f5', 100: '#e0e0e0', 200: '#b0b0b0', 300: '#808080', 400: '#505050', 500: '#303030', 600: '#252525', 700: '#1a1a1a', 800: '#111111', 900: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="font-tajawal bg-dark-900 text-white min-h-screen overflow-hidden">
  <!-- Animated golden background -->
  <div class="fixed inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900"></div>
    <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 40%, rgba(212,175,55,0.4) 0%, rgba(212,175,55,0.1) 40%, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 30% 60%, rgba(184,150,12,0.3) 0%, transparent 50%);"></div>
    <div class="absolute bottom-0 left-0 right-0 h-1/3 bg-gradient-to-t from-dark-900/90 to-transparent"></div>
  </div>

  <!-- Content -->
  <div class="relative z-10 flex flex-col items-center justify-center min-h-screen px-6">
    <div class="text-center animate-fadeIn">
      <!-- Logo/Brand area -->
      <div class="mb-12">
        <div class="w-20 h-20 mx-auto mb-6 rounded-2xl bg-gradient-to-br from-gold-400/20 to-gold-600/10 backdrop-blur-sm border border-gold-400/20 flex items-center justify-center">
          <svg class="w-10 h-10 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6"/>
          </svg>
        </div>
      </div>

      <h1 class="text-3xl md:text-5xl font-bold mb-6 leading-relaxed">
        لو حابب تدخل علي موقعنا الرئيسي
      </h1>

      <p class="text-dark-200 text-lg mb-12 max-w-md mx-auto">
        اكتشف أحدث مشاريعنا العقارية وعروضنا الحصرية
      </p>

      <a href="https://golfhousedevelopment.com/"
         target="_blank"
         rel="noopener noreferrer"
         class="group inline-flex items-center gap-3 px-10 py-4 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold text-xl rounded-2xl shadow-lg shadow-gold-400/25 hover:shadow-xl hover:shadow-gold-400/40 transform hover:scale-105 transition-all duration-300">
        <span>أنتقال للموقع الرئيسي</span>
        <svg class="w-6 h-6 transform rotate-180 group-hover:-translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
        </svg>
      </a>
    </div>
  </div>

  <!-- Subtle floating particles -->
  <div class="fixed inset-0 z-5 pointer-events-none overflow-hidden">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
    <div class="particle particle-4"></div>
    <div class="particle particle-5"></div>
  </div>
</body>
</html>
