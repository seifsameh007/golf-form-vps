<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { tajawal: ['Tajawal', 'sans-serif'] },
          colors: {
            gold: { 50: '#fdf9e7', 100: '#fbf0b5', 200: '#f5e06b', 300: '#e8c820', 400: '#d4af37', 500: '#b8960c', 600: '#957a0a', 700: '#715c08', 800: '#4d3f06', 900: '#2a2103' },
            dark: { 50: '#f5f5f5', 100: '#e0e0e0', 200: '#b0b0b0', 300: '#808080', 400: '#505050', 500: '#303030', 600: '#252525', 700: '#1a1a1a', 800: '#111111', 900: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>

<body class="font-tajawal bg-dark-900 text-white min-h-screen">
  <div class="flex min-h-screen">
    <!-- Mobile Overlay -->
    <div id="sidebarOverlay" class="lg:hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden"></div>

    <!-- Sidebar -->
    <aside id="sidebar"
      class="w-72 bg-dark-800/90 backdrop-blur-xl border-l border-dark-600/50 flex flex-col fixed right-0 top-0 bottom-0 z-50 transform translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
      <div class="p-6 border-b border-dark-600/50">
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-gold-400/30 to-gold-600/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-white">Golf House</h2>
            <p class="text-xs text-dark-300">لوحة التحكم</p>
          </div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-2">
        <a href="/dashboard"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
          <span class="font-medium">لمحة</span>
        </a>
        <a href="/dashboard/projects"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 <%= page === 'projects' ? 'bg-gold-400/10 text-gold-400 border border-gold-400/20' : 'text-dark-200 hover:bg-dark-700/50 hover:text-white' %>">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="font-medium">المشروعات</span>
        </a>
        <a href="/dashboard/requests"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="font-medium">الطلبات</span>
        </a>
        <a href="/dashboard/projects"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="font-medium">المشروعات</span>
        </a>
        <a href="/dashboard/team"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 bg-gold-400/10 text-gold-400 border border-gold-400/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
          </svg>
          <span class="font-medium">الإدارة</span>
        </a>
      </nav>
      <div class="p-4 border-t border-dark-600/50">
        <div class="flex items-center gap-3 px-3 py-2">
          <div
            class="relative w-10 h-10 rounded-full border-2 border-gold-400/30 overflow-hidden bg-dark-700 flex items-center justify-center shrink-0">
            <span class="text-gold-400 font-bold uppercase">
              <%= (user.name || 'A').charAt(0) %>
            </span>
            <% if (user.photo) { %>
              <img src="<%= user.photo %>" alt="<%= user.name %>" class="absolute inset-0 w-full h-full object-cover"
                referrerpolicy="no-referrer" onerror="this.style.display='none';">
              <% } %>
          </div>
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm truncate">
              <%= user.name %>
            </p>
            <p class="text-xs text-dark-300 truncate">
              <%= user.email %>
            </p>
          </div>
        </div>
        <a href="/auth/logout"
          class="mt-3 w-full flex items-center justify-center gap-2 px-4 py-2 text-sm text-red-400 hover:bg-red-400/10 rounded-xl transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          تسجيل خروج
        </a>
      </div>
    </aside>

    <!-- Mobile sidebar toggle -->
    <button id="sidebarToggle"
      class="lg:hidden fixed top-4 left-4 z-[60] w-12 h-12 bg-dark-800/90 backdrop-blur-xl rounded-xl flex items-center justify-center text-white border border-dark-600/50 shadow-lg transition-all hover:bg-dark-700/90 hover:border-gold-400/30">
      <svg id="menuIcon" class="w-6 h-6 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Main Content -->
    <main class="flex-1 lg:mr-72 p-4 lg:p-8 pt-20 lg:pt-8 w-full overflow-x-hidden">
      <div class="mb-8">
        <h1 class="text-3xl font-bold">فريق الإدارة</h1>
        <p class="text-dark-300 mt-1">أعضاء الفريق المسجلين</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        <% team.forEach(member=> { %>
          <div
            class="bg-dark-800/60 backdrop-blur border border-dark-600/30 rounded-2xl p-6 hover:border-gold-400/20 transition-all duration-300">
            <div class="flex items-center gap-4">
              <div
                class="relative w-16 h-16 rounded-2xl border-2 border-dark-500 bg-dark-700 flex items-center justify-center shrink-0 overflow-visible">
                <div class="w-full h-full rounded-2xl overflow-hidden flex items-center justify-center relative">
                  <span class="text-gold-400 font-bold text-2xl uppercase">
                    <%= (member.name || 'A').charAt(0) %>
                  </span>
                  <% if (member.photo) { %>
                    <img src="<%= member.photo %>" alt="<%= member.name %>"
                      class="absolute inset-0 w-full h-full object-cover" referrerpolicy="no-referrer"
                      onerror="this.style.display='none';">
                    <% } %>
                </div>

                <% if (member.isOnline) { %>
                  <div
                    class="absolute -bottom-1 -left-1 w-5 h-5 bg-green-500 rounded-full border-2 border-dark-800 z-10">
                  </div>
                  <% } else { %>
                    <div
                      class="absolute -bottom-1 -left-1 w-5 h-5 bg-dark-500 rounded-full border-2 border-dark-800 z-10">
                    </div>
                    <% } %>
              </div>
              <div class="flex-1">
                <h3 class="font-bold text-lg">
                  <%= member.name %>
                </h3>
                <p class="text-dark-400 text-sm">
                  <%= member.email %>
                </p>
                <div class="flex items-center gap-2 mt-2">
                  <% if (member.isOnline) { %>
                    <span class="flex items-center gap-1.5 text-green-400 text-sm font-medium">
                      <span class="w-2 h-2 bg-green-400 rounded-full animate-pulse"></span>
                      Online
                    </span>
                    <% } else { %>
                      <span class="flex items-center gap-1.5 text-dark-400 text-sm">
                        <span class="w-2 h-2 bg-dark-500 rounded-full"></span>
                        Offline
                      </span>
                      <% if (member.lastOnline) { %>
                        <span class="text-dark-500 text-xs">
                          • آخر ظهور: <%= new Date(member.lastOnline).toLocaleDateString('ar-EG', { month: 'short' ,
                            day: 'numeric' , hour: '2-digit' , minute: '2-digit' }) %>
                        </span>
                        <% } %>
                          <% } %>
                </div>
              </div>
            </div>
            <div class="mt-4 pt-4 border-t border-dark-600/30">
              <span
                class="px-3 py-1 rounded-lg text-xs font-medium <%= member.role === 'admin' ? 'bg-gold-400/10 text-gold-400 border border-gold-400/20' : 'bg-dark-600/50 text-dark-300 border border-dark-500/30' %>">
                <%= member.role==='admin' ? '👑 مدير' : '👤 عضو' %>
              </span>
            </div>
          </div>
          <% }) %>
      </div>

      <% if (team.length===0) { %>
        <div class="text-center py-16 text-dark-400">
          <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197" />
          </svg>
          <p class="text-lg">لا يوجد أعضاء في الفريق</p>
        </div>
        <% } %>
    </main>
  </div>
  <!-- Sidebar Logic -->
  <script>
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebarToggle');
    const overlay = document.getElementById('sidebarOverlay');
    const menuIcon = document.getElementById('menuIcon');
    
    function openSidebar() {
      if(sidebar && overlay && menuIcon) {
        sidebar.classList.remove('translate-x-full');
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />';
      }
    }

    function closeSidebar() {
      if(sidebar && overlay && menuIcon) {
        sidebar.classList.add('translate-x-full');
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />';
      }
    }

    if (toggle && sidebar && overlay && menuIcon) {
      toggle.addEventListener('click', () => {
        if (!sidebar.classList.contains('translate-x-full')) closeSidebar();
        else openSidebar();
      });
      
      overlay.addEventListener('click', closeSidebar);
      
      sidebar.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth < 1024) closeSidebar();
        });
      });
    }

    let touchstartX = 0;
    let touchstartY = 0;
    let touchendX = 0;
    let touchendY = 0;

    document.addEventListener('touchstart', e => {
      touchstartX = e.changedTouches[0].screenX;
      touchstartY = e.changedTouches[0].screenY;
    }, {passive: true});

    document.addEventListener('touchend', e => {
      touchendX = e.changedTouches[0].screenX;
      touchendY = e.changedTouches[0].screenY;
      
      const swipedX = touchstartX - touchendX;
      const swipedY = touchstartY - touchendY;
      
      if (Math.abs(swipedX) > Math.abs(swipedY) && Math.abs(swipedX) > 50) {
        if (swipedX > 0) { // Swiped left
           if (window.innerWidth < 1024) openSidebar();
        } else { // Swiped right
           if (window.innerWidth < 1024) closeSidebar();
        }
      }
    }, {passive: true});
  </script>
</body>

</html>