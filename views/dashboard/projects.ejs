<!DOCTYPE html>
<html lang="ar" dir="rtl">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>
    <%= title %>
  </title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap"
    rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { tajawal: ['Tajawal', 'sans-serif'] },
          colors: {
            gold: { 50: '#fdf9e7', 100: '#fbf0b5', 200: '#f5e06b', 300: '#e8c820', 400: '#d4af37', 500: '#b8960c', 600: '#957a0a', 700: '#715c08', 800: '#4d3f06', 900: '#2a2103' },
            dark: { 50: '#f5f5f5', 100: '#e0e0e0', 200: '#b0b0b0', 300: '#808080', 400: '#505050', 500: '#303030', 600: '#252525', 700: '#1a1a1a', 800: '#111111', 900: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>

<body class="font-tajawal bg-dark-900 text-white min-h-screen">
  <div class="flex min-h-screen">
    <!-- Mobile Overlay -->
    <div id="sidebarOverlay" class="lg:hidden fixed inset-0 bg-black/50 backdrop-blur-sm z-40 hidden"></div>

    <!-- Sidebar -->
    <aside id="sidebar"
      class="w-72 bg-dark-800/90 backdrop-blur-xl border-l border-dark-600/50 flex flex-col fixed right-0 top-0 bottom-0 z-50 transform translate-x-full lg:translate-x-0 transition-transform duration-300 ease-in-out">
      <div class="p-6 border-b border-dark-600/50">
        <div class="flex items-center gap-3">
          <div
            class="w-10 h-10 rounded-xl bg-gradient-to-br from-gold-400/30 to-gold-600/10 flex items-center justify-center">
            <svg class="w-5 h-5 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                d="M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" />
            </svg>
          </div>
          <div>
            <h2 class="font-bold text-white">Golf House</h2>
            <p class="text-xs text-dark-300">لوحة التحكم</p>
          </div>
        </div>
      </div>
      <nav class="flex-1 p-4 space-y-2">
        <a href="/dashboard"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zm10 0a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" />
          </svg>
          <span class="font-medium">لمحة</span>
        </a>
        <a href="/dashboard/projects"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 bg-gold-400/10 text-gold-400 border border-gold-400/20">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
          </svg>
          <span class="font-medium">المشروعات</span>
        </a>
        <a href="/dashboard/requests"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" />
          </svg>
          <span class="font-medium">الطلبات</span>
        </a>
        <a href="/dashboard/team"
          class="sidebar-link flex items-center gap-3 px-4 py-3 rounded-xl transition-all duration-200 text-dark-200 hover:bg-dark-700/50 hover:text-white">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M12 4.354a4 4 0 110 5.292M15 21H3v-1a6 6 0 0112 0v1zm0 0h6v-1a6 6 0 00-9-5.197m13.5-9a2.5 2.5 0 11-5 0 2.5 2.5 0 015 0z" />
          </svg>
          <span class="font-medium">الإدارة</span>
        </a>
      </nav>
      <div class="p-4 border-t border-dark-600/50">
        <div class="flex items-center gap-3 px-3 py-2">
          <img src="<%= user.photo %>" alt="<%= user.name %>"
            class="w-10 h-10 rounded-full border-2 border-gold-400/30 object-cover" referrerpolicy="no-referrer">
          <div class="flex-1 min-w-0">
            <p class="font-medium text-sm truncate">
              <%= user.name %>
            </p>
            <p class="text-xs text-dark-300 truncate">
              <%= user.email %>
            </p>
          </div>
        </div>
        <a href="/auth/logout"
          class="mt-3 w-full flex items-center justify-center gap-2 px-4 py-2 text-sm text-red-400 hover:bg-red-400/10 rounded-xl transition-all">
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
              d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
          </svg>
          تسجيل خروج
        </a>
      </div>
    </aside>

    <!-- Mobile sidebar toggle -->
    <button id="sidebarToggle"
      class="lg:hidden fixed top-4 left-4 z-[60] w-12 h-12 bg-dark-800/90 backdrop-blur-xl rounded-xl flex items-center justify-center text-white border border-dark-600/50 shadow-lg transition-all hover:bg-dark-700/90 hover:border-gold-400/30">
      <svg id="menuIcon" class="w-6 h-6 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />
      </svg>
    </button>

    <!-- Main Content -->
    <main class="flex-1 lg:mr-72 p-4 lg:p-8 pt-20 lg:pt-8 w-full overflow-x-hidden">
      <div class="flex items-center justify-between mb-8">
        <div>
          <h1 class="text-3xl font-bold">المشروعات والصيغ</h1>
          <p class="text-dark-300 mt-1">إضافة النماذج والمشروعات المختلفة وإنشاء روابط لها</p>
        </div>
        <button onclick="toggleModal()"
          class="flex items-center gap-2 px-6 py-3 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold rounded-xl shadow-lg hover:shadow-xl hover:scale-105 transition-all">
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
          </svg>
          مشروع جديد
        </button>
      </div>

      <!-- Projects Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <% if (projects.length===0) { %>
          <div class="col-span-1 lg:col-span-2 text-center py-16 bg-dark-800/50 rounded-2xl border border-dark-600/30">
            <svg class="w-16 h-16 mx-auto mb-4 text-dark-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
                d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" />
            </svg>
            <p class="text-dark-300">لا توجد مشاريع مضافة حالياً. ابدأ بإضافة مشروع جديد.</p>
          </div>
          <% } %>

            <% projects.forEach(project=> { %>
              <div
                class="bg-dark-800/80 backdrop-blur border border-dark-600/30 rounded-2xl p-6 hover:border-gold-400/30 transition-all flex flex-col justify-between group">
                <div>
                  <div class="flex items-center justify-between mb-4">
                    <h3 class="text-xl font-bold text-white">
                      <%= project.name %>
                    </h3>
                    <div class="flex items-center gap-1">
                      <button data-id="<%= project._id %>" data-name="<%= project.name %>"
                        data-rooms="<%= project.rooms.join(',') %>" onclick="openEditModal(this)"
                        class="p-2 text-gold-400 hover:bg-gold-400/10 rounded-lg transition-all border border-transparent hover:border-gold-400/20"
                        title="تعديل">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M15.232 5.232l3.536 3.536m-2.036-5.036a2.5 2.5 0 113.536 3.536L6.5 21.036H3v-3.572L16.732 3.732z" />
                        </svg>
                      </button>
                      <button onclick="deleteProject('<%= project._id %>')"
                        class="p-2 text-red-500 hover:bg-red-500/10 rounded-lg transition-all border border-transparent hover:border-red-500/20"
                        title="حذف">
                        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                            d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </div>
                  </div>
                  <div class="mb-4">
                    <span class="text-xs bg-dark-700 text-dark-300 px-3 py-1 rounded-full border border-dark-600">
                      <%= project.slug %>
                    </span>
                  </div>
                  <p class="text-sm font-bold text-gold-400 mb-2">عدد الغرف المتاحة:</p>
                  <div class="flex flex-wrap gap-2 mb-6">
                    <% project.rooms.forEach(room=> { %>
                      <span
                        class="bg-dark-700/50 text-dark-200 border border-dark-600/50 px-3 py-1.5 rounded-lg text-sm">
                        <%= room %>
                      </span>
                      <% }) %>
                  </div>
                </div>

                <div class="mt-4 pt-4 border-t border-dark-700 flex gap-3">
                  <button onclick="copyLink(this, '<%= project.slug %>')"
                    class="flex-1 flex items-center justify-center gap-2 px-4 py-2 bg-gold-400/10 text-gold-400 rounded-xl hover:bg-gold-400/20 transition-all border border-gold-400/20 text-sm font-medium">
                    <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M13.828 10.172a4 4 0 00-5.656 0l-4 4a4 4 0 105.656 5.656l1.102-1.101m-.758-4.899a4 4 0 005.656 0l4-4a4 4 0 00-5.656-5.656l-1.1 1.1" />
                    </svg>
                    <span>نسخ الرابط المباشر</span>
                  </button>
                  <a href="/form/<%= project.slug %>" target="_blank"
                    class="flex items-center justify-center p-2 bg-dark-700 text-white rounded-xl hover:bg-dark-600 transition-all border border-dark-600">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                        d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
                    </svg>
                  </a>
                </div>
              </div>
              <% }) %>
      </div>
    </main>
  </div>

  <!-- Add Project Modal -->
  <div id="addModal" class="fixed inset-0 z-[100] hidden">
    <div class="absolute inset-0 bg-dark-900/80 backdrop-blur-sm" onclick="toggleModal()"></div>
    <div
      class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full max-w-lg bg-dark-800 border border-dark-600/50 rounded-3xl p-8 shadow-2xl">
      <div class="flex items-center justify-between mb-6">
        <h2 id="modalTitle" class="text-2xl font-bold">إضافة مشروع جديد</h2>
        <button onclick="toggleModal()" class="text-dark-400 hover:text-white p-2">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>

      <form id="projectForm" onsubmit="addProject(event)">
        <div class="space-y-5">
          <div>
            <label class="block text-sm font-bold text-gold-400 mb-2">اسم المشروع</label>
            <input type="text" id="projectName" required placeholder="مثال: Porto Grande"
              class="w-full py-3 px-4 bg-dark-900 border border-dark-600 rounded-xl text-white outline-none focus:border-gold-400 transition-all">
          </div>
          <div>
            <label class="block text-sm font-bold text-gold-400 mb-2">أقسام الغرف المتاحة</label>
            <p class="text-xs text-dark-300 mb-3">أضف عنصراً واضغط "إضافة" أو Enter. يمكنك سحب العناصر بالأيقونة لإعادة
              ترتيبها.</p>
            <div class="flex gap-2">
              <input type="text" id="roomInput" placeholder="مثال: أستوديو" onkeypress="handleRoomKeyPress(event)"
                class="flex-1 py-3 px-4 bg-dark-900 border border-dark-600 rounded-xl text-white outline-none focus:border-gold-400 transition-all">
              <button type="button" onclick="addRoomTag()"
                class="px-6 py-3 bg-dark-700 text-white rounded-xl hover:bg-gold-500 hover:text-dark-900 font-bold transition-all border border-dark-600 flex items-center justify-center gap-2">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                </svg>
                <span>إضافة</span>
              </button>
            </div>
            <!-- Interactive Room Tags Area -->
            <div id="roomTagsContainer"
              class="flex flex-col gap-2 mt-4 min-h-[60px] p-2 bg-dark-900/50 rounded-xl border border-dark-600/30">
              <!-- Rendered via JS -->
            </div>

            <input type="hidden" id="projectRooms" required>
          </div>
        </div>
        <div class="mt-8">
          <button type="submit"
            class="w-full py-4 text-center bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all">
            حفظ وإضافة
          </button>
        </div>
      </form>
    </div>
  </div>

  <script>
    let roomTags = [];
    let currentEditId = null;

    function toggleModal() {
      const modal = document.getElementById('addModal');
      if (modal.classList.contains('hidden')) {
        // Reset form when opening
        currentEditId = null;
        document.getElementById('modalTitle').innerText = 'إضافة مشروع جديد';
        document.getElementById('projectName').value = '';
        document.getElementById('roomInput').value = '';
        roomTags = [];
        renderRoomTags();
        modal.classList.remove('hidden');
        document.getElementById('projectName').focus();
      } else {
        modal.classList.add('hidden');
      }
    }

    // Dynamic Room tags logic
    function handleRoomKeyPress(e) {
      if (e.key === 'Enter') {
        e.preventDefault();
        addRoomTag();
      }
    }

    function addRoomTag() {
      const input = document.getElementById('roomInput');
      const val = input.value.trim();
      if (val && !roomTags.includes(val)) {
        roomTags.push(val);
        input.value = '';
        renderRoomTags();
      } else {
        input.value = '';
      }
    }

    function removeRoomTag(index) {
      roomTags.splice(index, 1);
      renderRoomTags();
    }

    function renderRoomTags() {
      const container = document.getElementById('roomTagsContainer');
      const hiddenInput = document.getElementById('projectRooms');
      hiddenInput.value = roomTags.join(',');

      container.innerHTML = '';
      if (roomTags.length === 0) {
        container.innerHTML = '<span class="text-dark-400 text-sm text-center block w-full py-2">لا توجد أقسام، يرجى إضافة الإقسام بالاعلى</span>';
        return;
      }

      roomTags.forEach((tag, index) => {
        const div = document.createElement('div');
        div.className = 'flex items-center justify-between bg-dark-800 border border-dark-600 p-3 rounded-xl cursor-move group hover:border-gold-400/50 hover:bg-dark-700 transition-all';
        div.draggable = true;
        div.dataset.index = index;

        div.addEventListener('dragstart', handleDragStart);
        div.addEventListener('dragover', handleDragOver);
        div.addEventListener('drop', handleDrop);
        div.addEventListener('dragenter', handleDragEnter);

        div.innerHTML = `
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 text-dark-500 group-hover:text-gold-400 transition-all" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 8h16M4 16h16"/></svg>
            <span class="font-bold text-white">${tag}</span>
          </div>
          <button type="button" onclick="removeRoomTag(${index})" class="text-dark-400 hover:text-red-400 p-2 bg-dark-700/50 hover:bg-red-400/10 rounded-lg transition-all border border-transparent hover:border-red-400/20">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
          </button>
        `;
        container.appendChild(div);
      });
    }

    let dragStartIndex;

    function handleDragStart(e) {
      dragStartIndex = Number(e.currentTarget.dataset.index);
      e.dataTransfer.effectAllowed = 'move';
      // Make it slightly transparent and highlight to denote moving
      setTimeout(() => e.target.classList.add('opacity-50'), 0);
    }

    function handleDragOver(e) {
      e.preventDefault(); // Necessary to allow dropping
      e.dataTransfer.dropEffect = 'move';
      return false;
    }

    function handleDragEnter(e) {
      e.preventDefault();
    }

    function handleDrop(e) {
      e.stopPropagation();
      const dragEndIndex = Number(e.currentTarget.dataset.index);
      e.currentTarget.classList.remove('opacity-50');
      if (dragStartIndex !== undefined && dragStartIndex !== dragEndIndex) {
        const itemOne = roomTags[dragStartIndex];
        roomTags.splice(dragStartIndex, 1);
        roomTags.splice(dragEndIndex, 0, itemOne);
        renderRoomTags();
      }
      return false;
    }

    function openEditModal(btn) {
      currentEditId = btn.dataset.id;
      const modal = document.getElementById('addModal');
      document.getElementById('modalTitle').innerText = 'تعديل المشروع: ' + btn.dataset.name;
      document.getElementById('projectName').value = btn.dataset.name;

      roomTags = btn.dataset.rooms.split(',').filter(r => r.trim() !== '');
      renderRoomTags();

      modal.classList.remove('hidden');
    }

    async function deleteProject(id) {
      if (!confirm('هل أنت متأكد من حذف هذا المشروع نهائياً؟')) return;
      try {
        const res = await fetch('/api/projects/' + id, { method: 'DELETE' });
        const data = await res.json();
        if (data.success) {
          window.location.reload();
        } else {
          alert(data.error || 'حدث خطأ');
        }
      } catch (err) {
        alert('حدث خطأ');
      }
    }

    async function addProject(e) {
      e.preventDefault();
      const name = document.getElementById('projectName').value;
      const rooms = document.getElementById('projectRooms').value;

      try {
        const isEdit = !!currentEditId;
        const url = isEdit ? '/api/projects/' + currentEditId : '/api/projects';
        const method = isEdit ? 'PUT' : 'POST';

        const res = await fetch(url, {
          method,
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ name, rooms })
        });

        const data = await res.json();

        if (data.success) {
          window.location.reload();
        } else {
          alert(data.error || 'حدث خطأ');
        }
      } catch (err) {
        alert('حدث خطأ في النظام');
      }
    }

    function copyLink(btn, slug) {
      const url = window.location.origin + '/form/' + slug;
      navigator.clipboard.writeText(url).then(() => {
        const span = btn.querySelector('span');
        const originalText = span.innerText;
        span.innerText = 'تم النسخ!';
        btn.classList.replace('text-gold-400', 'text-green-400');
        btn.classList.replace('border-gold-400/20', 'border-green-400/20');
        btn.classList.replace('bg-gold-400/10', 'bg-green-400/10');

        setTimeout(() => {
          span.innerText = originalText;
          btn.classList.replace('text-green-400', 'text-gold-400');
          btn.classList.replace('border-green-400/20', 'border-gold-400/20');
          btn.classList.replace('bg-green-400/10', 'bg-gold-400/10');
        }, 2000);
      });
    }
  </script>
  <!-- Sidebar Logic -->
  <script>
    const sidebar = document.getElementById('sidebar');
    const toggle = document.getElementById('sidebarToggle');
    const overlay = document.getElementById('sidebarOverlay');
    const menuIcon = document.getElementById('menuIcon');
    
    function openSidebar() {
      if(sidebar && overlay && menuIcon) {
        sidebar.classList.remove('translate-x-full');
        overlay.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />';
      }
    }

    function closeSidebar() {
      if(sidebar && overlay && menuIcon) {
        sidebar.classList.add('translate-x-full');
        overlay.classList.add('hidden');
        document.body.style.overflow = '';
        menuIcon.innerHTML = '<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M9 5l7 7-7 7" />';
      }
    }

    if (toggle && sidebar && overlay && menuIcon) {
      toggle.addEventListener('click', () => {
        if (!sidebar.classList.contains('translate-x-full')) closeSidebar();
        else openSidebar();
      });
      
      overlay.addEventListener('click', closeSidebar);
      
      sidebar.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (window.innerWidth < 1024) closeSidebar();
        });
      });
    }

    let touchstartX = 0;
    let touchstartY = 0;
    let touchendX = 0;
    let touchendY = 0;

    document.addEventListener('touchstart', e => {
      touchstartX = e.changedTouches[0].screenX;
      touchstartY = e.changedTouches[0].screenY;
    }, {passive: true});

    document.addEventListener('touchend', e => {
      touchendX = e.changedTouches[0].screenX;
      touchendY = e.changedTouches[0].screenY;
      
      const swipedX = touchstartX - touchendX;
      const swipedY = touchstartY - touchendY;
      
      if (Math.abs(swipedX) > Math.abs(swipedY) && Math.abs(swipedX) > 50) {
        if (swipedX > 0) { // Swiped left
           if (window.innerWidth < 1024) openSidebar();
        } else { // Swiped right
           if (window.innerWidth < 1024) closeSidebar();
        }
      }
    }, {passive: true});
  </script>
</body>

</html>