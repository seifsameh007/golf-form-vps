<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <meta name="description" content="<%= project.name %> - سجل بياناتك واحجز استشارتك المجانية">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link href="https://fonts.googleapis.com/css2?family=Tajawal:wght@300;400;500;700;800;900&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/styles.css">
  <script>
    tailwind.config = {
      theme: {
        extend: {
          fontFamily: { tajawal: ['Tajawal', 'sans-serif'] },
          colors: {
            gold: { 50: '#fdf9e7', 100: '#fbf0b5', 200: '#f5e06b', 300: '#e8c820', 400: '#d4af37', 500: '#b8960c', 600: '#957a0a', 700: '#715c08', 800: '#4d3f06', 900: '#2a2103' },
            dark: { 50: '#f5f5f5', 100: '#e0e0e0', 200: '#b0b0b0', 300: '#808080', 400: '#505050', 500: '#303030', 600: '#252525', 700: '#1a1a1a', 800: '#111111', 900: '#0a0a0a' }
          }
        }
      }
    }
  </script>
</head>
<body class="font-tajawal bg-dark-900 text-white min-h-screen">
  <!-- Background -->
  <div class="fixed inset-0 z-0">
    <div class="absolute inset-0 bg-gradient-to-br from-dark-900 via-dark-800 to-dark-900"></div>
    <div class="absolute inset-0 opacity-30" style="background: radial-gradient(ellipse at 50% 30%, rgba(212,175,55,0.4) 0%, rgba(212,175,55,0.1) 40%, transparent 70%);"></div>
    <div class="absolute inset-0 opacity-20" style="background: radial-gradient(ellipse at 30% 60%, rgba(184,150,12,0.3) 0%, transparent 50%);"></div>
  </div>

  <!-- Floating Particles -->
  <div class="fixed inset-0 z-5 pointer-events-none overflow-hidden">
    <div class="particle particle-1"></div>
    <div class="particle particle-2"></div>
    <div class="particle particle-3"></div>
  </div>

  <!-- Main Content -->
  <div class="relative z-10 min-h-screen flex flex-col items-center py-8 px-4">
    <!-- Project Name -->
    <h1 class="text-4xl md:text-5xl font-black mb-8 text-white tracking-wide"><%= project.name %></h1>

    <!-- Step Progress Icons -->
    <div class="flex items-center gap-0 mb-8" id="progressBar">
      <!-- Step 1: Rooms -->
      <div class="step-icon active" data-step="1">
        <div class="w-12 h-12 rounded-full bg-dark-600/80 backdrop-blur border-2 border-gold-400 flex items-center justify-center transition-all duration-300">
          <svg class="w-6 h-6 text-gold-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 7v10a2 2 0 002 2h14a2 2 0 002-2V9a2 2 0 00-2-2h-6l-2-2H5a2 2 0 00-2 2z"/></svg>
        </div>
      </div>
      <div class="w-8 h-0.5 bg-dark-500 step-line" data-line="1"></div>
      <!-- Step 2: Contact -->
      <div class="step-icon" data-step="2">
        <div class="w-12 h-12 rounded-full bg-dark-600/80 backdrop-blur border-2 border-dark-500 flex items-center justify-center transition-all duration-300">
          <svg class="w-6 h-6 text-dark-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        </div>
      </div>
      <div class="w-8 h-0.5 bg-dark-500 step-line" data-line="2"></div>
      <!-- Step 3: Schedule -->
      <div class="step-icon" data-step="3">
        <div class="w-12 h-12 rounded-full bg-dark-600/80 backdrop-blur border-2 border-dark-500 flex items-center justify-center transition-all duration-300">
          <svg class="w-6 h-6 text-dark-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
      </div>
      <div class="w-8 h-0.5 bg-dark-500 step-line" data-line="3"></div>
      <!-- Step 4: Summary -->
      <div class="step-icon" data-step="4">
        <div class="w-12 h-12 rounded-full bg-dark-600/80 backdrop-blur border-2 border-dark-500 flex items-center justify-center transition-all duration-300">
          <svg class="w-6 h-6 text-dark-300" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
        </div>
      </div>
    </div>

    <!-- Form Container -->
    <div class="w-full max-w-lg">
      <!-- STEP 1: Room Selection -->
      <div class="form-step active" id="step1">
        <div class="glass-card p-8 rounded-3xl">
          <h2 class="text-2xl font-bold text-center mb-8">عدد الغرف اللي حضرتك محتاجها ؟</h2>
          <div class="flex flex-col gap-4">
            <% project.rooms.forEach(room => { %>
            <button onclick="selectRoom('<%= room %>')" class="room-btn group w-full py-4 px-8 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold text-xl rounded-2xl shadow-lg shadow-gold-400/20 hover:shadow-xl hover:shadow-gold-400/40 transform hover:scale-[1.03] transition-all duration-300">
              <%= room %>
            </button>
            <% }) %>
          </div>
          
          <input type="hidden" id="projectId" value="<%= project._id %>">
        </div>
      </div>

      <!-- STEP 2: Contact Info -->
      <div class="form-step" id="step2">
        <div class="glass-card p-8 rounded-3xl">
          <h2 class="text-2xl font-bold text-center mb-8">من فضلك اديني بيانات التواصل</h2>

          <div class="space-y-5">
            <div>
              <label class="block text-sm font-bold text-gold-400 mb-2 text-right">أسم حضرتك</label>
              <input type="text" id="clientName" required placeholder="الأسم بالكامل"
                class="form-input w-full py-3 px-4 bg-dark-500/60 backdrop-blur border border-dark-400/50 rounded-xl text-white placeholder-dark-300 focus:border-gold-400 focus:ring-1 focus:ring-gold-400/50 transition-all outline-none text-right">
            </div>

            <div>
              <label class="block text-sm font-bold text-gold-400 mb-2 text-right">رقم تيليفون للتواصل</label>
              <input type="tel" id="clientPhone" required placeholder="01xxxxxxxxx"
                class="form-input w-full py-3 px-4 bg-dark-500/60 backdrop-blur border border-dark-400/50 rounded-xl text-white placeholder-dark-300 focus:border-gold-400 focus:ring-1 focus:ring-gold-400/50 transition-all outline-none text-right" dir="ltr" style="text-align:right">
            </div>

            <label class="flex items-center gap-3 justify-end cursor-pointer group">
              <span class="text-sm text-dark-200 group-hover:text-gold-400 transition-colors">عندي رقم واتساب مختلف</span>
              <div class="relative flex items-center justify-center">
                <input type="checkbox" id="noWhatsApp" onchange="toggleWhatsAppInput()" class="peer appearance-none w-6 h-6 rounded-full border-2 border-dark-400 bg-dark-600/50 checked:bg-gold-400 checked:border-gold-400 cursor-pointer transition-all outline-none focus:ring-2 focus:ring-gold-400/50 focus:ring-offset-2 focus:ring-offset-dark-900">
                <svg class="absolute w-4 h-4 text-dark-900 pointer-events-none opacity-0 peer-checked:opacity-100 transition-opacity" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="3">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M5 13l4 4L19 7" />
                </svg>
              </div>
            </label>

            <!-- WhatsApp number field (hidden by default) -->
            <div id="whatsappInputContainer" class="hidden animate-fadeIn">
              <label class="block text-sm font-bold text-gold-400 mb-2 text-right">رقم الواتساب للتواصل</label>
              <input type="tel" id="clientWhatsApp" placeholder="01xxxxxxxxx"
                class="form-input w-full py-3 px-4 bg-dark-500/60 backdrop-blur border border-dark-400/50 rounded-xl text-white placeholder-dark-300 focus:border-gold-400 focus:ring-1 focus:ring-gold-400/50 transition-all outline-none text-right" dir="ltr" style="text-align:right">
            </div>

            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-bold text-gold-400 mb-2 text-right">بريد الكتروني <span class="text-dark-300 font-normal">"أختياري"</span></label>
                <input type="email" id="clientEmail" placeholder="example@mail.com"
                  class="form-input w-full py-3 px-4 bg-dark-500/60 backdrop-blur border border-dark-400/50 rounded-xl text-white placeholder-dark-300 focus:border-gold-400 focus:ring-1 focus:ring-gold-400/50 transition-all outline-none text-right" dir="ltr" style="text-align:right">
              </div>
              <div>
                <label class="block text-sm font-bold text-gold-400 mb-2 text-right">مسمي وظيفي <span class="text-dark-300 font-normal">"أختياري"</span></label>
                <input type="text" id="clientJob" placeholder="مهندس، طبيب..."
                  class="form-input w-full py-3 px-4 bg-dark-500/60 backdrop-blur border border-dark-400/50 rounded-xl text-white placeholder-dark-300 focus:border-gold-400 focus:ring-1 focus:ring-gold-400/50 transition-all outline-none text-right">
              </div>
            </div>
          </div>

          <div class="flex gap-4 mt-8">
            <button onclick="goToStep(1)" class="flex-1 py-3 px-6 bg-dark-600/80 text-dark-200 font-bold rounded-xl hover:bg-dark-500 transition-all">
              رجوع
            </button>
            <button onclick="validateAndGoToStep3()" class="flex-1 py-3 px-6 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold rounded-xl shadow-lg shadow-gold-400/20 hover:shadow-xl hover:shadow-gold-400/40 transform hover:scale-[1.02] transition-all">
              التالي
            </button>
          </div>
        </div>
      </div>

      <!-- STEP 3: Schedule -->
      <div class="form-step" id="step3">
        <div class="glass-card p-8 rounded-3xl">
          <h2 class="text-2xl font-bold text-center mb-8">حضرتك تحب نتواصل معاك امتي ؟</h2>

          <!-- Immediate Call -->
          <div class="mb-4 flex flex-col items-center justify-center">
            <button onclick="toggleImmediateCall(this)" id="immediateCallBtn" class="w-full py-4 px-6 bg-gradient-to-l from-green-500/20 via-green-600/10 to-green-500/20 border border-green-500/50 hover:border-green-400 text-green-100 font-bold text-xl rounded-xl shadow-lg transition-all flex items-center justify-center gap-3">
              <svg class="w-6 h-6 text-green-500" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              طلب مكالمة فورية
            </button>
            <p id="immediateNotice" class="hidden text-green-400 text-sm font-bold mt-3 animate-fadeIn">هيتم الاتصال بحضرتك خلال 5 إلى 15 دقيقة</p>
          </div>

          <div class="flex items-center justify-center gap-4 mb-6">
            <div class="h-px bg-dark-500 flex-1"></div>
            <span class="text-dark-300 font-bold text-sm">أو حجز موعد</span>
            <div class="h-px bg-dark-500 flex-1"></div>
          </div>

          <!-- Day Selection -->
          <div class="mb-6" id="regularScheduleContainer">
            <h3 class="text-lg font-bold text-right mb-4 text-gold-400">: اليوم</h3>
            <div class="flex gap-4 justify-center">
              <button onclick="selectDay('النهارده', this)" class="day-btn px-8 py-3 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold text-lg rounded-xl shadow-lg shadow-gold-400/20 hover:shadow-xl transition-all active-day">
                النهارده
              </button>
              <button onclick="selectDay('بكره', this)" class="day-btn px-8 py-3 bg-dark-500/60 text-dark-200 font-bold text-lg rounded-xl border border-dark-400/50 hover:border-gold-400/50 transition-all">
                بكره
              </button>
            </div>
          </div>

          <!-- Time Picker -->
          <div class="mb-6" id="timePickerContainer">
            <h3 class="text-lg font-bold text-center mb-4 text-gold-400">الساعه</h3>
            <div class="time-picker-container bg-dark-600/60 backdrop-blur rounded-2xl border border-dark-400/30 overflow-hidden">
              <div class="time-picker-highlight"></div>
              <div class="time-picker-scroll" id="timePicker">
                <!-- Times will be populated by JS -->
              </div>
              <div class="time-picker-fade-top"></div>
              <div class="time-picker-fade-bottom"></div>
            </div>
          </div>

          <div class="flex gap-4 mt-8">
            <button onclick="goToStep(2)" class="flex-1 py-3 px-6 bg-dark-600/80 text-dark-200 font-bold rounded-xl hover:bg-dark-500 transition-all">
              رجوع
            </button>
            <button onclick="goToStep(4)" class="flex-1 py-3 px-6 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold rounded-xl shadow-lg shadow-gold-400/20 hover:shadow-xl hover:shadow-gold-400/40 transform hover:scale-[1.02] transition-all">
              التالي
            </button>
          </div>
        </div>
      </div>

      <!-- STEP 4: Summary -->
      <div class="form-step" id="step4">
        <div class="glass-card p-8 rounded-3xl">
          <h2 class="text-2xl font-bold text-center mb-8">ملخص الطلب</h2>

          <div class="space-y-4">
            <!-- Rooms Summary -->
            <div class="bg-dark-600/60 backdrop-blur rounded-2xl p-5 border border-dark-400/20">
              <span class="text-gold-400 font-bold text-sm">: عدد الغرف</span>
              <p class="text-white text-lg font-bold mt-1" id="summaryRooms">-</p>
            </div>

            <!-- Contact Summary -->
            <div class="bg-dark-600/60 backdrop-blur rounded-2xl p-5 border border-dark-400/20">
              <span class="text-gold-400 font-bold text-sm">: بيانات التواصل</span>
              <div class="mt-2 space-y-1">
                <p class="text-white" id="summaryName">-</p>
                <p class="text-dark-200" id="summaryPhone">-</p>
                <p class="text-dark-200" id="summaryEmail" style="display:none">-</p>
                <p class="text-dark-200" id="summaryJob" style="display:none">-</p>
              </div>
            </div>

            <!-- Schedule Summary -->
            <div class="bg-dark-600/60 backdrop-blur rounded-2xl p-5 border border-dark-400/20">
              <span class="text-gold-400 font-bold text-sm">: معاد التواصل</span>
              <div class="mt-2">
                <p class="text-white" id="summaryDay">-</p>
                <p class="text-dark-200" id="summaryTime">-</p>
              </div>
            </div>
          </div>

          <div class="flex gap-4 mt-8">
            <button onclick="goToStep(3)" class="flex-1 py-3 px-6 bg-dark-600/80 text-dark-200 font-bold rounded-xl hover:bg-dark-500 transition-all">
              رجوع
            </button>
            <button onclick="submitForm()" id="submitBtn" class="flex-1 py-4 px-6 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-extrabold text-lg rounded-xl shadow-lg shadow-gold-400/25 hover:shadow-xl hover:shadow-gold-400/40 transform hover:scale-[1.02] transition-all">
              إرسال الطلب ✨
            </button>
          </div>
        </div>
      </div>

      <!-- SUCCESS Screen -->
      <div class="form-step" id="stepSuccess">
        <div class="text-center py-16 animate-fadeIn">
          <div class="w-24 h-24 mx-auto mb-6 rounded-full bg-gradient-to-br from-green-400/20 to-green-600/10 backdrop-blur border border-green-400/30 flex items-center justify-center">
            <svg class="w-12 h-12 text-green-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="text-3xl font-bold mb-4 text-green-400">تم إرسال الطلب بنجاح!</h2>
          <p class="text-dark-200 text-lg mb-8" id="successMessageText">هنتواصل مع حضرتك في أقرب وقت</p>
          <a href="https://golfhousedevelopment.com/" class="inline-flex items-center gap-2 px-8 py-3 bg-gradient-to-l from-gold-300 via-gold-400 to-gold-300 text-dark-900 font-bold rounded-xl shadow-lg hover:shadow-xl transition-all">
            زيارة الموقع الرئيسي
            <svg class="w-5 h-5 rotate-180" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
        </div>
      </div>
    </div>
  </div>

  <script src="/js/timePicker.js"></script>
  <script src="/js/form.js"></script>
</body>
</html>
